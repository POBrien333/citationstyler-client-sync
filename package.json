{
  "name": "citationstyler-client-sync",
  "type": "module",
  "version": "1.0.5",
  "description": "A Zotero plugin for managing and installing custom citation styles with license validation.",
  "config": {
    "addonName": "Citation Styler Client Sync",
    "addonID": "citationstyler-sync@citationstyler.com",
    "addonRef": "citationstyler-sync",
    "addonInstance": "CitationStylerSync",
    "prefsPrefix": "extensions.zotero.citationstyler-sync"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/POBrien333/citationstyler-client-sync.git"
  },
  "author": {
    "name": "Citation Styler",
    "email": "info@citationstyler.com",
    "url": "https://citationstyler.com/en/"
  },
  "bugs": {
    "url": "https://github.com/POBrien333/citationstyler-client-sync/issues"
  },
  "homepage": "https://citationstyler.com/en/",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "core-js": "^3.48.0",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.5",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  },
  "keywords": [
    "zotero",
    "citation",
    "styles",
    "license",
    "plugin"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
